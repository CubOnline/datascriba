# Database
DATABASE_URL=postgresql://datascriba:datascriba@localhost:5432/datascriba

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0

# Auth
BETTER_AUTH_SECRET=change-this-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001

# Encryption (AES-256-GCM master key for connection strings, 32-byte hex)
ENCRYPTION_MASTER_KEY=change-this-to-32-bytes-hex-value-xx

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Scriba AI (Phase 5)
# Anthropic API key -- https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model -- default: claude-sonnet-4-6
AI_MODEL=claude-sonnet-4-6

# AI endpoint rate limit (requests per minute per IP)
AI_RATE_LIMIT_RPM=10

# Queue / Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Worker — Internal API
INTERNAL_API_URL=http://localhost:3001

# SMTP (optional — report email notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-password
# SMTP_FROM=no-reply@datascriba.io
